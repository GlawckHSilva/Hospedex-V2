NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
HOSPEDEX_SUPABASE_SERVICE_ROLE_KEY=

HOSPEDEX_API_ENV=local
HOSPEDEX_API_NAME=Hospedex API
HOSPEDEX_API_VERSION=0.1.0
HOSPEDEX_DOCS_URL=/docs
HOSPEDEX_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
HOSPEDEX_DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
HOSPEDEX_DATABASE_SSL=auto
HOSPEDEX_DATABASE_SET_ROLE=true
HOSPEDEX_SUPABASE_JWT_SECRET=
HOSPEDEX_SUPABASE_JWT_AUDIENCE=authenticated
HOSPEDEX_SUPABASE_JWT_ISSUER=
HOSPEDEX_REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=

# Comunicacao por e-mail no Gerenciamento.
# RESEND_API_KEY deve ficar apenas no servidor/Vercel, nunca como NEXT_PUBLIC.
# Enquanto nao houver dominio verificado, usar modo teste com onboarding@resend.dev.
RESEND_API_KEY=
EMAIL_MODE=test
EMAIL_FROM=Hospedex <onboarding@resend.dev>
EMAIL_REPLY_TO=
EMAIL_TEST_RECIPIENT=
APP_PUBLIC_URL=https://hospedex.vercel.app

# Jobs internos do Admin/Vercel Cron.
# CRON_SECRET protege endpoints /api/cron contra execucao publica.
CRON_SECRET=

# Previsao do tempo para mensagens automaticas antes do check-in.
# Padrao atual: Open-Meteo server-side, sem chave obrigatoria.
WEATHER_PROVIDER=open-meteo
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
WEATHER_GEOCODING_API_URL=https://geocoding-api.open-meteo.com/v1/search
WEATHER_API_KEY=

# Conversao informativa de moedas no Marketplace.
# Padrao atual: Frankfurter (server-side, sem chave obrigatoria).
# AwesomeAPI tambem e suportada via CURRENCY_API_PROVIDER=awesomeapi.
CURRENCY_API_PROVIDER=frankfurter
CURRENCY_API_KEY=
CURRENCY_API_BASE_URL=https://api.frankfurter.dev
CURRENCY_CACHE_TTL_SECONDS=3600
