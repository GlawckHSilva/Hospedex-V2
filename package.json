{
  "name": "hospedex-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.14.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:marketplace": "npm run dev -w @hospedex/marketplace",
    "dev:gestao": "npm run dev -w @hospedex/gestao",
    "dev:admin": "npm run dev -w @hospedex/admin",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "api:dev": "python -m uvicorn api.main:app --reload --app-dir services/api-python"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
